generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  PENDING
  STREAMING
  COMPLETE
  ERROR
}

enum AiRunStatus {
  RUNNING
  COMPLETE
  ERROR
}

enum CanvasType {
  NOTES
  CANVAS
}

enum MemoryItemKind {
  DECISION
  QUESTION
  ACTION_ITEM
  CONTEXT
}

enum PresenceStatus {
  ONLINE
  AWAY
  OFFLINE
}

// ─── Identity ─────────────────────────────────────────────────────────────

/// Standard NextAuth-compatible User model. `image` + `emailVerified` are
/// required by `@next-auth/prisma-adapter` — the adapter writes those exact
/// column names from OAuth profiles. The DTO layer renames `image` →
/// `avatarUrl` on the wire so client code stays unchanged.
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  /// bcrypt-hashed password. Optional because users who signed up via OAuth
  /// (Google/GitHub) won't have one — they authenticate through the provider.
  /// Email+password users get this populated at registration.
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // NextAuth
  accounts Account[]
  sessions Session[]

  // Domain
  memberships     WorkspaceMember[]
  messages        Message[]
  ownedWorkspaces Workspace[]       @relation("WorkspaceOwner")
  presence        PresenceState[]
  invitesSent     WorkspaceInvite[] @relation("InvitesSent")
  invitesUsed     WorkspaceInvite[] @relation("InvitesUsed")
  // Team memory back-refs
  // (no direct user→embedding link; embeddings are keyed by message)
}

/// NextAuth OAuth account links. Standard adapter shape — do not rename
/// columns; the adapter maps them positionally.
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

/// NextAuth database session. Present and ready, but the app currently runs
/// the JWT session strategy (the dev CredentialsProvider requires it). Rows
/// here populate once the deploy switches `session.strategy` to "database".
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

/// NextAuth email/passwordless verification tokens.
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Workspace ────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User              @relation("WorkspaceOwner", fields: [ownerId], references: [id])
  members       WorkspaceMember[]
  conversations Conversation[]
  canvases      CanvasDocument[]
  presence      PresenceState[]
  invites       WorkspaceInvite[]
  embeddings    Embedding[]
  memoryItems   MemoryItem[]

  @@index([ownerId])
}

/// Vector embedding for a single message. Powers Team Memory: semantic
/// retrieval of past conversations ("what did we decide about X").
///
/// `embedding` is a pgvector(768) column (Gemini text-embedding-004
/// dimensions). Prisma doesn't natively type vector columns, so it's
/// declared `Unsupported` and read/written via raw queries; everything
/// else (relations, indexes) is regular Prisma.
///
/// One row per message, enforced by `@unique` on `messageId`. The HNSW
/// index for fast cosine similarity is added in the migration SQL
/// (Prisma can't emit `USING hnsw` directly yet).
model Embedding {
  id             String   @id @default(cuid())
  messageId      String   @unique
  conversationId String
  workspaceId    String
  content        String   @db.Text
  embedding      Unsupported("vector(768)")?
  /// Postgres-generated tsvector of `content` (english stemmer). Powers
  /// the BM25 half of hybrid retrieval — merged with the vector cosine
  /// hits via reciprocal rank fusion at query time. Read-only from the
  /// app's perspective; the column is `GENERATED ALWAYS AS (...) STORED`
  /// so Postgres maintains it automatically and Prisma never writes it.
  contentTsv     Unsupported("tsvector")?
  createdAt      DateTime @default(now())

  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([conversationId])
}

/// Structured nuggets extracted from a completed AI turn — decisions made,
/// questions still open, action items, ambient context worth remembering.
/// The "Memory" panel renders these grouped by kind.
///
/// Written fire-and-forget by the extractor after each AI run completes —
/// a failed extraction never blocks the user-facing response. `messageId`
/// points back to the assistant message that produced the item (nullable;
/// SET NULL on message delete keeps the memory intact even if the source
/// is purged). `ownerId` is a loose assignee for ACTION_ITEM; resolving
/// flips `resolvedAt`.
model MemoryItem {
  id             String         @id @default(cuid())
  workspaceId    String
  conversationId String
  messageId      String?
  kind           MemoryItemKind
  text           String         @db.Text
  ownerId        String?
  dueAt          DateTime?
  resolvedAt     DateTime?
  /// Last time a human said "this is still true" — resets the staleness
  /// clock for DECISION/CONTEXT kinds. Null = never reconfirmed since
  /// extraction, so staleness measures from `createdAt`.
  confirmedAt    DateTime?
  /// pgvector embedding of `text`, written at insert time. Powers the
  /// operation-emitter dedup pipeline — before persisting a freshly
  /// extracted fact we cosine-search this column inside the workspace
  /// for near-duplicates and let the LLM decide ADD/UPDATE/DELETE/NONE.
  /// Same dimensionality as the message embeddings (Gemini, 768).
  embedding      Unsupported("vector(768)")?
  /// When a newer item supersedes this one (team revised a decision,
  /// reversed a commitment), `supersededById` points to the replacement
  /// and `supersededReason` carries the LLM's short rationale. Live
  /// memory views filter to `supersededById IS NULL`; superseded items
  /// remain queryable for the per-item history trail.
  supersededById   String?
  supersededReason String?  @db.Text
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  workspace    Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message?     @relation(fields: [messageId], references: [id], onDelete: SetNull)
  supersededBy MemoryItem?  @relation("MemoryItemSupersession", fields: [supersededById], references: [id], onDelete: SetNull)
  supersedes   MemoryItem[] @relation("MemoryItemSupersession")

  @@index([workspaceId, kind])
  @@index([conversationId])
  @@index([workspaceId, resolvedAt])
  @@index([supersededById])
}

/// Single-use invite tokens that grant membership on /invite/[token].
/// `usedAt` + `usedById` populate on the first successful accept; subsequent
/// visits either redirect the existing member into the workspace or report
/// the invite as already used.
model WorkspaceInvite {
  id          String     @id @default(cuid())
  token       String     @unique
  workspaceId String
  role        MemberRole @default(EDITOR)
  invitedById String
  expiresAt   DateTime
  usedAt      DateTime?
  usedById    String?
  createdAt   DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invitedBy User      @relation("InvitesSent", fields: [invitedById], references: [id], onDelete: Cascade)
  usedBy    User?     @relation("InvitesUsed", fields: [usedById], references: [id])

  @@index([workspaceId])
  @@index([invitedById])
}

/// The authorization boundary — every realtime and data op is gated on a
/// row here. `cursorColor` is allocated once at join time.
model WorkspaceMember {
  id          String     @id @default(cuid())
  workspaceId String
  userId      String
  role        MemberRole @default(EDITOR)
  cursorColor String
  joinedAt    DateTime   @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
}

// ─── Conversation ─────────────────────────────────────────────────────────

model Conversation {
  id          String   @id @default(cuid())
  workspaceId String
  title       String   @default("New conversation")
  summary     String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  messages    Message[]
  aiRuns      AiRun[]
  embeddings  Embedding[]
  memoryItems MemoryItem[]

  @@index([workspaceId, createdAt])
}

/// Append-mostly. `serverSeq` is the per-conversation ordering authority and
/// the cursor for keyset pagination + reconnect catch-up. `clientMsgId`
/// makes prompt submission idempotent across reconnect retries.
model Message {
  id             String        @id @default(cuid())
  conversationId String
  role           MessageRole
  authorId       String?
  content        String        @db.Text
  status         MessageStatus @default(COMPLETE)
  clientMsgId    String?
  serverSeq      Int
  tokenUsage     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  completedAt    DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  author       User?        @relation(fields: [authorId], references: [id])
  aiRun        AiRun?
  embedding    Embedding?
  memoryItems  MemoryItem[]

  @@unique([conversationId, clientMsgId])
  @@unique([conversationId, serverSeq])
  @@index([conversationId, serverSeq])
  @@index([conversationId, createdAt])
  @@index([authorId])
}

model AiRun {
  id             String      @id @default(cuid())
  conversationId String
  messageId      String      @unique
  status         AiRunStatus @default(RUNNING)
  model          String
  error          String?     @db.Text
  startedAt      DateTime    @default(now())
  completedAt    DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([conversationId, startedAt])
  @@index([status])
}

// ─── Shared canvas / notes ────────────────────────────────────────────────

/// Materialized snapshot + version. The snapshot is a periodic compaction of
/// the op log so clients don't replay the full history on load.
model CanvasDocument {
  id          String     @id @default(cuid())
  workspaceId String
  type        CanvasType @default(NOTES)
  snapshot    Json       @default("{}")
  version     Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  workspace  Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  operations CanvasOperation[]

  @@index([workspaceId])
}

/// Append-only op log. `serverSeq` orders ops within a document and doubles
/// as the catch-up cursor.
model CanvasOperation {
  id               String   @id @default(cuid())
  canvasDocumentId String
  actorId          String
  serverSeq        Int
  op               Json
  createdAt        DateTime @default(now())

  document CanvasDocument @relation(fields: [canvasDocumentId], references: [id], onDelete: Cascade)

  @@unique([canvasDocumentId, serverSeq])
  @@index([canvasDocumentId, serverSeq])
  @@index([actorId])
}

// ─── Presence ─────────────────────────────────────────────────────────────

/// Durable presence. Redis remains the live, high-churn broadcast layer;
/// this table is the persistent fallback — "last active 2h ago" when a
/// member is offline, plus a recovery source if Redis is flushed. Written
/// on connect/disconnect transitions, NOT on every heartbeat or cursor move.
model PresenceState {
  id          String         @id @default(cuid())
  workspaceId String
  userId      String
  status      PresenceStatus @default(OFFLINE)
  lastSeenAt  DateTime       @default(now())
  lastCursor  Json?
  updatedAt   DateTime       @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, userId])
  @@index([workspaceId, status])
  @@index([userId])
}
